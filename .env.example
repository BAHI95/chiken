NODE_ENV=development

# Web/public runtime config
WEB_BASE_URL=http://127.0.0.1:5500
API_BASE_URL=http://127.0.0.1:8787/api
PUBLIC_WEB_BASE_URL=http://127.0.0.1:5500
PUBLIC_API_BASE_URL=http://127.0.0.1:8787/api
PUBLIC_ENVIRONMENT=development
PUBLIC_SUPPORT_EMAIL=support@example.com
SUPPORT_EMAIL=support@example.com

# API server
HOST=127.0.0.1
PORT=8787
SESSION_DAYS=30
SESSION_SECRET=change-me-in-production
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5512,http://localhost:5512

# Database
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/chicken_platform
DATABASE_SSL=false
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECT_TIMEOUT_MS=10000

# Email / Auth
AUTH_REQUIRE_EMAIL_VERIFICATION=false
EMAIL_FROM=Farm Platform <no-reply@example.com>
RESEND_API_KEY=
PASSWORD_RESET_HOURS=2
VERIFICATION_HOURS=48

# Operations
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_AUTH=25
BACKUP_DIR=apps/api/backups
BACKUP_RETENTION_COUNT=14
